[node name="Text2" type="RichTextLabel" parent="Content/Genetics"]
clip_contents = false
custom_minimum_size = Vector2(330, 0)
layout_mode = 2
text = "* When you pollinate flowers the seeds they produce get one gene from each parent per locus.

* Punnet squares help visualize the outcome of a cross by showing the possible combinations of the parents' genes."
fit_content = true

