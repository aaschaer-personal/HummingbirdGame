[node name="Text1" type="RichTextLabel" parent="Content/Genetics"]
clip_contents = false
custom_minimum_size = Vector2(330, 0)
layout_mode = 2
bbcode_enabled = true
text = "[font_size=12]
[font_size=24][center]Genetics[/center][font_size=12]

* Traits such as flower color and number of flowers are determined by genetics. Each trait is determined by one or more loci, each with two genes that come in different forms called alleles. For example, the color of sunflowers is determined by a single locus with two alleles R and Y. A sunflower with two R genes will be red, two Y genes will be yellow, and one of each will be orange."
fit_content = true

