[node name="Text1" type="RichTextLabel" parent="Content/GrowingFlowers"]
clip_contents = false
custom_minimum_size = Vector2(330, 0)
layout_mode = 2
bbcode_enabled = true
text = "[font_size=12]
[font_size=24][center]Growing Flowers[/center][font_size=12]

* To grow flowers, plant seeds in bare soil using a seed packet then water with a watering can."
fit_content = true

[node name="PlantAndWater" type="TextureRect" parent="Content/GrowingFlowers"]
layout_mode = 2
size_flags_horizontal = 4
size_flags_vertical = 4
texture = ExtResource("14_xxw3f")
stretch_mode = 2

[node name="Text2" type="RichTextLabel" parent="Content/GrowingFlowers"]
clip_contents = false
custom_minimum_size = Vector2(330, 0)
layout_mode = 2
text = "* Watered seeds will sprout, grow, and bloom. After sprouting plants don't need water but will grow and make nectar faster if kept watered."
fit_content = true

[node name="SeedToFlower" type="TextureRect" parent="Content/GrowingFlowers"]
layout_mode = 2
size_flags_horizontal = 4
size_flags_vertical = 4
texture = ExtResource("15_4fsxb")
stretch_mode = 2

[node name="Text3" parent="Content/GrowingFlowers" instance=ExtResource("6_rfbbp")]
clip_contents = false
layout_mode = 2
text = "* Interact with an individual flower (left click or %interact) to drink energy restoring nectar and get its pollen on your beak."

[node name="Drink" type="TextureRect" parent="Content/GrowingFlowers"]
layout_mode = 2
size_flags_horizontal = 4
size_flags_vertical = 4
texture = ExtResource("16_j6486")
stretch_mode = 2

[node name="Text4" type="RichTextLabel" parent="Content/GrowingFlowers"]
clip_contents = false
custom_minimum_size = Vector2(330, 0)
layout_mode = 2
text = "* Drinking from a flower with pollen on your beak will pollinate it, after which it will go to seed and no longer provide nectar."
fit_content = true

[node name="Pollinate" type="TextureRect" parent="Content/GrowingFlowers"]
layout_mode = 2
size_flags_horizontal = 4
size_flags_vertical = 4
texture = ExtResource("17_srugb")
stretch_mode = 2

[node name="Text5" type="RichTextLabel" parent="Content/GrowingFlowers"]
clip_contents = false
custom_minimum_size = Vector2(330, 0)
layout_mode = 2
text = "* Drinking from multiple flowers will mix their pollen together on your beak. The next flower you pollinate could then produce seeds with pollen from any of those flowers, but the last flower you drank from is most likely."
fit_content = true

[node name="Text6" parent="Content/GrowingFlowers" instance=ExtResource("6_rfbbp")]
clip_contents = false
layout_mode = 2
text = "* Interact with a body of water (left click or %interact) to take a bath and clean off all pollen. Bathing regularly helps you control what pollen is used in pollination.
"

