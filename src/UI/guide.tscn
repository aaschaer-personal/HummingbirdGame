[node name="Controls" parent="Content" instance=ExtResource("6_rfbbp")]
custom_minimum_size = Vector2(330, 0)
layout_mode = 2
text = "[font_size=12]
[font_size=24][center]Controls[/center][font_size=12]

* Press %pause to pause, unpause, and exit menus.

* Move around with %up %left %down %right or by clicking on a destination.

* Interact with objects by left clicking on them, or by moving close to them and pressing %interact.

* Drop held items by right clicking or pressing %drop.

* Controls can be remapped in the Options menu."

[node name="UsingItems" type="VBoxContainer" parent="Content"]
visible = false
