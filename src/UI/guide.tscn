[node name="Text4" type="RichTextLabel" parent="Content/Genetics"]
clip_contents = false
custom_minimum_size = Vector2(330, 0)
layout_mode = 2
text = "* Pollinating a flower with itself or another closely related flower will cause the offpsring to be inbred. The more inbred a flower is the fewer seeds it will produce.

* Letting bees pollinate your flowers with random pollen will reduce inbreeding but only knowing one parent will make it harder to predict the traits of the resulting seeds."
fit_content = true

