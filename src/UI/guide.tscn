[node name="Text1" parent="Content/UsingItems" instance=ExtResource("6_rfbbp")]
clip_contents = false
custom_minimum_size = Vector2(330, 0)
layout_mode = 2
text = "[font_size=12]
[font_size=24][center]Using Items[/center][font_size=12]

* While not holding anything, interact with an item to pick it up. (left click or %interact to interact with something)


* While holding a seed packet:

     * Interact with a bare patch of soil to plant a seed.
"

